GITHUB_TOKEN=your_github_token_here
GITHUB_WEBHOOK_SECRET=your_webhook_secret_here

# Repository allowlist (comma-separated owner/repo pairs)
# Leave empty to allow all repos (not recommended for production)
# Example: ALLOWED_REPOS=user/repo2,org/project
ALLOWED_REPOS=

AI_PROVIDER=gemini
GEMINI_API_KEY=your_gemini_api_key_here
ANTHROPIC_API_KEY=your_anthropic_api_key_here
GITHUB_MODEL_TOKEN=your_github_model_token_here
LOG_LEVEL=INFO
